---
layout: layouts/base.njk
title: "Therapy — Jasmine Mote, PhD"
eleventyComputed:
  description: "{{ therapy.seo.description }}"
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Jasmine Mote, PhD",
  "url": "https://jasminemote.com/therapy/",
  "description": "Licensed clinical psychologist in the Boston area specializing in perinatal mental health, mood disorders, anxiety, OCD, and psychosis. Sees clients through Cambridge Psychology Group.",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Boston",
    "addressRegion": "MA",
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "State",
    "name": "Massachusetts"
  },
  "parentOrganization": {
    "@type": "MedicalOrganization",
    "name": "Cambridge Psychology Group",
    "url": "https://cambridgepsych.org"
  },
  "sameAs": [
    "https://cambridgepsych.org/clinicians/jasmine-mote/",
    "https://www.psychologytoday.com/us/therapists/jasmine-mote-arlington-ma/1050066"
  ]
}
</script>

{# ── PAGE HEADER ── #}
<section class="page-header">
  <div class="container">
    <p class="page-eyebrow">{{ therapy.page.eyebrow }}</p>
    <h1 class="page-headline">{{ therapy.page.headline | safe }}</h1>
    <p class="page-subhead">{{ therapy.page.subhead }}</p>
    <p class="page-affiliation">{{ therapy.page.affiliation }}</p>
    <div class="page-header-links">
      <a href="{{ therapy.page.cpg_url }}" class="btn-primary" target="_blank" rel="noopener">{{ therapy.page.cta_label }}</a>
    </div>
  </div>
</section>

{# ── THERAPY DETAIL ── #}
<section class="therapy-section" id="therapy">
  <div class="container">
    <div class="therapy-inner">
      <div>
        <div class="section-header">
          <h2 class="section-title">{{ therapy.specialties.section_title | safe }}</h2>
        </div>
        <ul class="specialty-list">
          {% for item in therapy.specialties.items %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      <div>
        <div class="therapy-card">
          <h3 class="therapy-card-title">{{ therapy.cta_card.title }}</h3>
          <p class="therapy-card-body">{{ therapy.cta_card.body }}</p>
          <a href="{{ therapy.cta_card.cpg_url }}" class="btn-primary" target="_blank" rel="noopener">{{ therapy.cta_card.cta_label }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

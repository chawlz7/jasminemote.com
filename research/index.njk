---
layout: layouts/base.njk
title: "Research — Jasmine Mote, PhD"
description: "Jasmine Mote's research focuses on emotion, social connection, and serious mental illness. Research Assistant Professor at Boston University Sargent College."
---

{# ── PAGE HEADER ── #}
<section class="page-header">
  <div class="container">
    <div class="page-header-inner">
      <div class="page-header-text">
        <p class="page-eyebrow">{{ research.statement.eyebrow }}</p>
        <h1 class="page-headline">{{ research.statement.headline | safe }}</h1>
        <p class="page-subhead">{{ research.statement.body }}</p>
        <p class="page-affiliation">{{ research.statement.affiliation }}</p>
        <div class="page-header-links">
          <a href="{{ '/cv.pdf' | url }}" class="btn-secondary">Download CV</a>
        </div>
      </div>
      <div class="page-header-logos">
        <a href="https://sites.bu.edu/amplab/" class="profile-logo-card" target="_blank" rel="noopener" aria-label="AMP Lab — Approach Motivation & Participation Lab">
          <img src="{{ '/logos/amp-lab.png' | url }}" alt="AMP Lab" width="180" height="44">
        </a>
        <a href="https://scholar.google.com/citations?user=achpZVQAAAAJ&hl=en" class="profile-logo-card" target="_blank" rel="noopener" aria-label="Google Scholar profile">
          <img src="{{ '/logos/google-scholar.png' | url }}" alt="Google Scholar" width="180" height="44">
        </a>
        <a href="https://www.researchgate.net/profile/Jasmine-Mote" class="profile-logo-card" target="_blank" rel="noopener" aria-label="ResearchGate profile">
          <img src="{{ '/logos/researchgate.png' | url }}" alt="ResearchGate" width="180" height="44">
        </a>
      </div>
    </div>
  </div>
</section>

{# ── STATS ── #}
<section class="research-page-stats">
  <div class="container">
    <div class="research-stats">
      {% for stat in research.stats %}
      <div class="stat-cell">
        <div class="stat-number">{{ stat.number }}</div>
        <div class="stat-label">{{ stat.label | safe }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── RESEARCH FOCUS AREAS ── #}
<section class="research-focus-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Research <em>Focus</em></h2>
    </div>
    <div class="research-focus-list">
      {% for area in research.focus_areas %}
      {% set areaPublications = publications | pubsByFocusArea(area.id) %}
      <div class="research-focus-card">
        <div class="rfc-number">0{{ loop.index }}</div>
        <div class="rfc-content">
          <h3 class="rfc-title">{{ area.title }}</h3>
          <p class="rfc-desc">{{ area.description }}</p>
          {% if areaPublications.length > 0 %}
          <div class="rfc-pubs">
            <p class="rfc-pubs-label">Noteworthy Publications</p>
            <div class="rfc-pubs-list">
              {% for pub in areaPublications %}
              <div class="rfc-pub-item{% if pub.url %} rfc-pub-item--linked{% endif %}">
                {% if pub.url %}
                <a href="{{ pub.url }}" target="_blank" rel="noopener" class="rfc-pub-link">
                {% endif %}
                <p class="pub-citation">
                  <span class="pub-authors-page">{{ pub.authors }}</span>
                  ({{ pub.year }}). {{ pub.title }}
                  {% if pub.journal %}<span class="pub-journal-page">{{ pub.journal }}</span>{% endif %}
                </p>
                {% if pub.url %}
                  <span class="pub-doi-link">View ↗</span>
                </a>
                {% endif %}
              </div>
              {% endfor %}
            </div>
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── PUBLICATIONS ── #}
<section class="publications-page-section">
  <div class="container">

    <div class="section-header">
      <h2 class="section-title">All <em>Publications</em></h2>
      <a href="https://scholar.google.com/citations?user=achpZVQAAAAJ&hl=en" class="section-link" target="_blank" rel="noopener">Google Scholar ↗</a>
    </div>

    {# Publication timeline — fully automatic from publications.json #}
    <div class="pub-timeline-label">Publications by year</div>
    <div class="pub-timeline-chart">
      {% for bar in publications | pubsChartData %}
      <a href="#y{{ bar.year }}" class="ptb-bar" style="height: {{ bar.height }}px" title="{{ bar.year }}: {{ bar.label }}"></a>
      {% endfor %}
    </div>
    <div class="pub-timeline-years">
      {% for bar in publications | pubsChartData %}
      <span>{{ bar.year }}</span>
      {% endfor %}
    </div>

    {# Year-grouped publications list #}
    {% for group in publications | groupByYear %}
    <div id="y{{ group.year }}" class="pub-year-group">
      <h3 class="pub-year-heading">{{ group.year }}</h3>
      <div class="pub-year-list">
        {% for pub in group.items %}
        <div class="pub-entry{% if pub.url %} pub-entry--linked{% endif %}">
          {% if pub.url %}
          <a href="{{ pub.url }}" target="_blank" rel="noopener" class="pub-entry-link">
          {% endif %}
          <p class="pub-citation">
            <span class="pub-authors-page">{{ pub.authors }}</span>
            ({{ pub.year }}). {{ pub.title }}
            {% if pub.journal %}<span class="pub-journal-page">{{ pub.journal }}</span>{% endif %}
          </p>
          {% if pub.url %}
            <span class="pub-doi-link">View ↗</span>
          </a>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}

    <div class="research-links">
      <a href="https://scholar.google.com/citations?user=achpZVQAAAAJ&hl=en" class="btn-secondary" target="_blank" rel="noopener">View on Google Scholar ↗</a>
    </div>

  </div>
</section>
